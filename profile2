<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile Form - Academic Pulse</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f2f2f2;
}

header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #6e99c0;
    padding: 10px 20px;
    color: white;
}

nav a {
    margin: 0 10px;
    text-decoration: none;
    color: white;
    font-weight: bold;
}

.container {
    max-width: 600px;
    background: white;
    padding: 30px;
    margin: 50px auto;
    border-radius: 10px;
    box-shadow: 0px 0px 10px gray;
}

h2 {
    text-align: center;
    color: #333;
}

label {
    display: block;
    margin-top: 15px;
    font-weight: bold;
}

input[type="text"],
input[type="number"],
input[type="date"],
input[type="password"] {
    width: 95%;
    padding: 10px;
    margin-top: 5px;
    border-radius: 5px;
    border: 1px solid #ccc;
}

.sex-group {
    display: flex;
    gap: 20px;
    margin-top: 10px;
    align-items: center;
}

.sex-group label {
    margin: 0;
    font-weight: normal;
}

/* BUTTON */
button {
    width: 100%;
    padding: 10px;
    margin-top: 25px;
    background-color: #4CAF50;
    color: white;
    border: none;
    border-radius: 5px;
    font-size: 16px;
    cursor: pointer;
}

button:hover {
    background-color: #45a049;
}

.divider {
    text-align: center;
    margin: 15px 0;
}
</style>
</head>

<body>

<header>
<a href="file:///C:/Users/osabe/OneDrive/Desktop/wawa/login.html">
    <img src="121-removebg-preview.png" alt="Logo" height="40">
</a>
    <h2>Academic Pulse</h2>
    <nav>
        <a href="ABOUT-US.html">About Us</a>
    </nav>
</header>

<div class="container">
<h2>Sign in Form</h2>

<!-- FORM -->
<form action="file:///C:/Users/osabe/OneDrive/Desktop/wawa/homepage.html">

<label>First Name</label>
<input type="text" name="fname" required>

<label>Middle Initial</label>
<input type="text" name="minitial" maxlength="1">

<label>Surname</label>
<input type="text" name="lname" required>

<label>Sex</label>
<div class="sex-group">
    <input type="radio" name="sex" id="male" value="Male" required>
    <label for="male">Male</label>

    <input type="radio" name="sex" id="female" value="Female">
    <label for="female">Female</label>
</div>

<label>Email</label>
<input 
type="email" 
name="email" 
placeholder="Enter Email" 
required 
pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$">

<label>Password</label>
<input type="password" name="password" required>

<label>Year Level and Course</label>
<input type="text" name="course" required>

<label>Age</label>
<input type="number" name="age" min="13" max="120" required>

<label>Birth Date</label>
<input type="date" name="bdate" required>

<label>Address</label>
<input type="text" name="address" required>

<label>Postal Code</label>
<input type="text" name="postal" required>

<button type="submit">Sign in</button>

</form>

<div class="divider">
    Already have an account?
</div>
<form action="login.html">
    <button type="submit">Go to Login</button>
</form>

</div>

</body>
</html>
