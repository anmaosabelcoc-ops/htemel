<style>
body {
    font-family: Arial, sans-serif;
    background-color: #f5f6f8;
    margin: 0;
}

/* Header */
.header {
    padding: 20px;
    font-size: 20px;
    font-weight: bold;
}

/* Title */
.title {
    font-size: 60px;
    margin-left: 40px;
    font-weight: bold;
}

/* Main layout */
.container {
    display: flex;
    justify-content: space-between;
    padding: 40px;
}

/* LEFT BOX (Assessment) */
.box {
    background: #e6e6e6;
    border-radius: 20px;
    width: 45%;
    padding: 30px;
    box-shadow: 8px 8px 0px #9bbad1;
}
.answer {
    width: 20px;
    height: 20px;
    margin-right: 15px;
}

.box label {
    display: block;
    margin: 15px 0;
    font-size: 18px;
}

.box-title {
    text-align: center;
    margin-bottom: 20px;
}

/* RIGHT SIDE */
.right {
    width: 45%;
}

/* QUOTE BOX */
.quote-box {
    background: #86b6cf;
    border-radius: 20px;
    padding: 30px;
    border: 5px solid black;
    height: 200px;
    position: relative;
    font-size: 40px;
}

.quote-box p {
    margin: 0;
}

.quote-author {
    position: absolute;
    bottom: 20px;
}

/* RATING BOX */
.rating-box {
    margin-top: 40px;
    background: #86b6cf;
    border-radius: 10px;
    padding: 20px;
    text-align: center;
}

.stars {
    font-size: 25px;
    margin: 10px 0;
}

button {
    padding: 10px 20px;
    border: none;
    border-radius: 20px;
    background: white;
    cursor: pointer;
}

button:hover {
    background: #ddd;
}
.rating {
    display: flex;
    flex-direction: row-reverse;
    justify-content: center;
}

.rating input {
    display: none;
}

.rating label {
    font-size: 30px;
    color: #ccc;
    cursor: pointer;
    transition: 0.3s;
}
.rating label:hover,
.rating label:hover ~ label {
    color: gold;
}
.rating input:checked ~ label {
    color: gold;
}
</style>
</head>

